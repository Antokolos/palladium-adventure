[application]

config/name="palladium-shooter"
run/main_scene="res://entry_point.tscn"
config/use_custom_user_dir=true
config/custom_user_dir_name="palladium-shooter"
config/project_settings_override="user://settings.ini"
boot_splash/image="res://addons/palladium/assets/images/nlblogo.png"
boot_splash/fullsize=false
boot_splash/bg_color=Color( 0.00392157, 0.0745098, 0.133333, 1 )
config/icon="res://icon.png"
config/auto_accept_quit=false

[autoload]

__InkRuntime="*res://addons/inkgd/runtime/static/ink_runtime.gd"
__PLDRT="*res://addons/palladium/core/singletons/pld_runtime.gd"

[debug]

gdscript/warnings/unused_variable=false
gdscript/warnings/unused_argument=false
gdscript/warnings/return_value_discarded=false

[display]

window/size/width=1920
window/size/height=1080
window/dpi/allow_hidpi=true
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[editor_plugins]

enabled=PoolStringArray( "res://addons/godot-credits/plugin.cfg", "res://addons/gut/plugin.cfg", "res://addons/inkgd/plugin.cfg", "res://addons/palladium/plugin.cfg", "res://addons/zylann.hterrain/plugin.cfg" )

[global]

pause=false

[gui]

common/drop_mouse_on_gui_input_disabled=true

